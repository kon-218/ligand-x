# Docker ignore file to reduce build context size
# This helps reduce build cache size

# Git
.git
.gitignore
.gitattributes

# Documentation
*.md
docs/
README*

# Node modules (for frontend)
node_modules/
frontend/node_modules/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment files
.env
.env.local
.env.*.local

# Test files
tests/
*.test.py
*_test.py

# Data directories (usually mounted as volumes)
data/
uploads/
qc_jobs/
qc_results_db/

# Docker files themselves
Dockerfile*
docker-compose*.yml
.dockerignore

# CI/CD
.github/
.gitlab-ci.yml

# Temporary files
*.tmp
*.log
*.bak
*.swp

# OS files
.DS_Store
Thumbs.db
