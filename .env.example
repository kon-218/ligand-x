# ============================================================
# Ligand-X Development Environment
# ============================================================
# Copy this file to .env for local development.
# .env is gitignored — never commit it.
#
# The UID/GID lines below are managed automatically by `make dev`.
# You only need to set ORCA_HOST_PATH manually if you use the QC service.
# ============================================================

# Docker user — set automatically by `make dev` (do not edit manually)
UID=1000
GID=1000

# ORCA quantum chemistry binary path
# Set this to the directory containing your ORCA installation on the host.
# Required if you use the QC service (make dev-qc or make dev).
# Example: ORCA_HOST_PATH=/opt/orca
ORCA_HOST_PATH=/opt/orca

# QC service secret key (any non-empty string works for development)
QC_SECRET_KEY=dev-secret-key-change-for-production

# Flower monitoring dashboard password
FLOWER_PASSWORD=dev-flower-password

# Database connection URL (required — no default in production)
DATABASE_URL=postgresql://ligandx:ligandx@postgres:5432/ligandx

# Redis connection URL (required — no default in production)
REDIS_URL=redis://redis:6379/0

# RabbitMQ password (required — no default in production)
RABBITMQ_PASSWORD=ligandx

# ============================================================
# Resource Limits (Optional — scales with your hardware)
# ============================================================
# Uncomment and customize these to tune CPU/memory allocations.
# See .env.production.template for complete documentation and production defaults.
# Format: SERVICE_CPU_LIMIT (cores), SERVICE_MEM_LIMIT (e.g., 4G, 512M)
#
# Example (for 16-core system):
#   GATEWAY_CPU_LIMIT=2
#   GATEWAY_MEM_LIMIT=2G
#   MD_CPU_LIMIT=4
#   MD_MEM_LIMIT=16G
#   WORKER_GPU_LONG_CPU_LIMIT=12
#   WORKER_GPU_LONG_MEM_LIMIT=48G
#
# See .env.production.template for a complete list with recommendations.
